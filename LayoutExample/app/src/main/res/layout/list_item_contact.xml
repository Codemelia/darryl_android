<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Circle avatar showing first initial -->
    <TextView
        android:id="@+id/textInitial"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_circle"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Full Name -->
    <TextView
        android:id="@+id/textFullName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/textInitial"
        android:layout_marginStart="14dp"
        android:layout_alignTop="@id/textInitial"
        android:textColor="#212121"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Email -->
    <TextView
        android:id="@+id/textEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textFullName"
        android:layout_toEndOf="@id/textInitial"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        android:textColor="#616161"
        android:textSize="13sp" />

    <!-- Date of Birth -->
    <TextView
        android:id="@+id/textDob"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textEmail"
        android:layout_toEndOf="@id/textInitial"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        android:textColor="#9E9E9E"
        android:textSize="12sp" />

    <!-- PIN badge (top-right corner) -->
    <TextView
        android:id="@+id/textPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_circle"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

</RelativeLayout>
